# Copy this file to .env and fill in real values (do NOT commit .env)

# MongoDB connection string (Atlas or self-hosted)
# Example format (Atlas): mongodb+srv://<username>:<password>@cluster0.mongodb.net/expense_db?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.mongodb.net/expense_db?retryWrites=true&w=majority"

# Flask secret key (or app secret)
SECRET_KEY="replace-with-a-random-secret"

# Optional
FLASK_ENV=development
